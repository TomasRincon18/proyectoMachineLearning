# Copy this file to .env and fill only the keys needed for the selected sources.

# ACLED credentials.
ACLED_EMAIL=
# Preferred for the current OAuth flow documented by ACLED.
ACLED_PASSWORD=
# Optional legacy key for older access workflows if still enabled on the account.
ACLED_KEY=

# NASA FIRMS API key, if this source is selected.
NASA_FIRMS_MAP_KEY=

# Optional: OpenSky credentials if authenticated requests are needed.
OPENSKY_USERNAME=
OPENSKY_PASSWORD=
