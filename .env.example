# Copy this file to .env and fill only the keys needed for the selected sources.

# ACLED may require credentials depending on the access method.
ACLED_EMAIL=
ACLED_KEY=

# NASA FIRMS API key, if this source is selected.
NASA_FIRMS_MAP_KEY=

# Optional: OpenSky credentials if authenticated requests are needed.
OPENSKY_USERNAME=
OPENSKY_PASSWORD=
